# ── 注册配置 ──────────────────────────────────────────
# YYDS Mail 密钥（必填）
ARCEE_SIGNUP_API_KEY=your_yydsmail_api_key

# 注册邮箱域名
ARCEE_SIGNUP_DOMAIN=xiaodai.eu.cc

# 本次注册账号数量
SIGNUP_COUNT=3

# ── 服务配置 ──────────────────────────────────────────
# 本地 Bearer 鉴权 Key（客户端请求时需携带，留空则不校验）
ARCEE_OPENAI_API_KEY=daiju

# 服务监听地址（容器内固定 0.0.0.0:8787，不需要改）
# ARCEE_LISTEN=0.0.0.0:8787

# 默认模型名（可选）
# ARCEE_BASE_MODEL=trinity-large-thinking

# 手动指定单个 access_token（可选，有 tokens/ 目录时忽略）
# ARCEE_ACCESS_TOKEN=

# ── 端口映射 ──────────────────────────────────────────
# 宿主机对外端口
LISTEN_PORT=8787
